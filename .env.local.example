# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Required for Midtrans webhook to activate premium access.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Midtrans Snap
MIDTRANS_SERVER_KEY=Mid-server-your-sandbox-server-key
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=Mid-client-your-sandbox-client-key
# Keep false while testing sandbox. Change to true only after replacing keys
# with production keys from the Midtrans production dashboard.
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Contact
NEXT_PUBLIC_WHATSAPP_NUMBER=628XXXXXXXXX
NEXT_PUBLIC_WHATSAPP_MESSAGE=Halo, saya ingin tanya lebih lanjut tentang BudgetNikah.
